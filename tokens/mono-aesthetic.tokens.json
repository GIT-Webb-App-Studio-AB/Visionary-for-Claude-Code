{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "mono-aesthetic — typography / Subtle",
  "color": {
    "bg": {
      "$value": "#0D0D0D",
      "$type": "color"
    },
    "primary": {
      "$value": "#00FF41",
      "$type": "color",
      "$description": "green terminal) or #FFB000 (amber terminal"
    },
    "accent": {
      "$value": "#444444",
      "$type": "color"
    }
  },
  "typography": {
    "display": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.02em",
      "$type": "dimension"
    },
    "leading": {
      "$value": 1.5,
      "$type": "number"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":500,\"damping\":35,\"mass\":0.5}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
