{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "proptech — industry / Expressive",
  "color": {
    "bg": {
      "$value": "#F9F7F4",
      "$type": "color",
      "$description": "warm off-white — property photography friendly"
    },
    "primary": {
      "$value": "#1A3A2A",
      "$type": "color",
      "$description": "deep forest green — premium property"
    },
    "accent": {
      "$value": "#C8A96E",
      "$type": "color",
      "$description": "warm gold — aspirational"
    }
  },
  "typography": {
    "display": {
      "$value": "Canela 400–700 (editorial real estate feel)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "DM Sans 400",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.02em",
      "$type": "dimension"
