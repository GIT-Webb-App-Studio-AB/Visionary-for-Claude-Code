{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "terminal-cli — modern / Subtle",
  "color": {
    "bg": {
      "$value": "#0D0D0D",
      "$type": "color"
    },
    "primary": {
      "$value": "#00FF41",
      "$type": "color",
      "$description": "matrix green — canonical terminal"
    },
    "accent": {
      "$value": "#FFB86C",
      "$type": "color",
      "$description": "amber — warnings, highlights"
    }
  },
  "typography": {
    "display": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "JetBrains Mono",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":500,\"damping\":50}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
