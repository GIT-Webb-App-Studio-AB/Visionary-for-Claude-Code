{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "aurora-mesh — morphisms / Expressive",
  "color": {
    "bg": {
      "$value": "#0A0A1A",
      "$type": "color",
      "$description": "— deep dark canvas that makes mesh gradients glow"
    },
    "primary": {
      "$value": "#7C3AED",
      "$type": "color",
      "$description": "— purple anchor in the aurora palette"
    },
    "accent": {
      "$value": "#06B6D4",
      "$type": "color",
      "$description": "— cyan that recalls polar light"
    }
  },
  "typography": {
    "display": {
      "$value": "Bricolage Grotesque",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Bricolage Grotesque 400 or Inter",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "-0.02em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "20px",
      "$type": "dimension"
    }
  }
}
