{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "gamification — modern / Kinetic",
  "color": {
    "bg": {
      "$value": "#1A1033",
      "$type": "color"
    },
    "primary": {
      "$value": "#F59E0B",
      "$type": "color",
      "$description": "amber — reward, achievement"
    },
    "accent": {
      "$value": "#8B5CF6",
      "$type": "color",
      "$description": "violet — levels, progress"
    }
  },
  "typography": {
    "display": {
      "$value": "Nunito ExtraBold",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Fredoka (or Nunito",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Kinetic",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":150,\"damping\":10,\"mass\":0.7}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "12px",
      "$type": "dimension"
