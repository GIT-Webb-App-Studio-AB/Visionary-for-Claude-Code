{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "sports-analytics — hybrid / Expressive",
  "color": {
    "bg": {
      "$value": "#0A0A14",
      "$type": "color",
      "$description": "deep dark"
    },
    "accent": {
      "$value": "#00E5FF",
      "$type": "color",
      "$description": "Electric accent — e.g.,  or #FF2D78 depending on team"
    }
  },
  "typography": {
    "display": {
      "$value": "Bebas Neue",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "DM Sans (tabular",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.04em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":300,\"damping\":20}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius-min": {
      "$value": "4px",
      "$type": "dimension"
    },
    "radius-max": {
      "$value": "8px",
      "$type": "dimension"
    }
  }
}
