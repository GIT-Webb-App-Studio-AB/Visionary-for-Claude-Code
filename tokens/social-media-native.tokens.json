{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "social-media-native — industry / Kinetic",
  "color": {
    "bg": {
      "$value": "#000000",
      "$type": "color",
      "$description": "platform-matched ( TikTok/X, #FAFAFA Instagram-light"
    },
    "accent": {
      "$value": "#FF2D55",
      "$type": "color",
      "$description": "engagement red) or #FF6900 (creator orange"
    }
  },
  "typography": {
    "display": {
      "$value": "Bricolage Grotesque 700–800 (native",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "system",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0em",
      "$type": "dimension"
    },
    "leading": {
      "$value": 1.3,
      "$type": "number"
    }
  },
  "motion": {
    "tier": {
      "$value": "Kinetic",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":400,\"damping\":20,\"mass\":0.8}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "50%",
      "$type": "dimension"
    }
  }
}
