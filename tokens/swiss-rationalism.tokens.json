{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "swiss-rationalism — historical / Subtle",
  "color": {
    "bg": {
      "$value": "#FFFFFF",
      "$type": "color"
    },
    "primary": {
      "$value": "#000000",
      "$type": "color"
    },
    "accent": {
      "$value": "#FF0000",
      "$type": "color"
    }
  },
  "typography": {
    "display": {
      "$value": "Neue Haas Grotesk (fallback: Helvetica Neue)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Helvetica Neue",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "-0.02em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":400,\"damping\":40}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "12px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
