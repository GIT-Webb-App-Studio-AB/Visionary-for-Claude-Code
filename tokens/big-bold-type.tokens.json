{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "big-bold-type — typography / Expressive",
  "color": {
    "bg": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "or #000000"
    },
    "primary": {
      "$value": "#000000",
      "$type": "color",
      "$description": "on white) / #FFFFFF (on black"
    },
    "accent": {
      "$value": "#FF4D00",
      "$type": "color"
    }
  },
  "typography": {
    "display": {
      "$value": "Cabinet Grotesk 900",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Cabinet Grotesk 400",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "-0.04em",
      "$type": "dimension"
    },
    "leading": {
      "$value": 0.9,
      "$type": "number"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":300,\"damping\":25,\"mass\":1}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
