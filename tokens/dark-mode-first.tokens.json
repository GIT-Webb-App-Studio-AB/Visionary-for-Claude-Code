{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "dark-mode-first — modern / Expressive",
  "color": {
    "bg": {
      "$value": "#09090B",
      "$type": "color",
      "$description": "zinc-950"
    },
    "primary": {
      "$value": "#FAFAFA",
      "$type": "color",
      "$description": "zinc-50"
    },
    "accent": {
      "$value": "#3B82F6",
      "$type": "color"
    },
    "elevation-model": {
      "$value": "#09090B",
      "$type": "color",
      "$description": "layered zinc scale —  → #18181B → #27272A → #3F3F46; no glows by default"
    }
  },
  "typography": {
    "display": {
      "$value": "Geist (or Inter)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Geist",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "-0.01em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
