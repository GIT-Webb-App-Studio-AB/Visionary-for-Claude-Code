{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "data-physicalization — extended / Expressive",
  "color": {
    "bg": {
      "$value": "#F8F8F8",
      "$type": "color",
      "$description": "clean data canvas"
    }
  },
  "typography": {
    "display": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "IBM Plex Sans",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":180,\"damping\":20}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
