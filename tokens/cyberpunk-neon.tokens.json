      "$type": "color",
      "$description": "— near-black with barely-perceptible blue"
    },
    "primary": {
      "$value": "#FF00FF",
      "$type": "color",
      "$description": "— magenta neon for primary CTAs"
    },
    "accent": {
      "$value": "#00FFAA",
      "$type": "color",
