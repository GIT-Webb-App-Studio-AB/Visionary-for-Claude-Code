{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "scientific-journal — graphic / Subtle",
  "color": {
    "bg": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "clinical white"
    },
    "primary": {
      "$value": "#1A1A1A",
      "$type": "color",
      "$description": "publication black"
    },
    "accent": {
      "$value": "#003087",
      "$type": "color",
      "$description": "academic blue — link and figure reference"
    }
  },
  "typography": {
    "display": {
      "$value": "STIX Two Text (or Computer Modern via web)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Source Serif 4",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":200,\"damping\":28}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
