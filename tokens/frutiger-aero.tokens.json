{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "frutiger-aero — morphisms / Expressive",
  "color": {
    "bg": {
      "$value": "#C8E8F4",
      "$type": "color",
      "$description": "— sky blue gradient that evokes Windows Vista Aero"
    },
    "primary": {
      "$value": "#4A90D9",
      "$type": "color",
      "$description": "— Vista-era button blue with glass sheen"
    },
    "accent": {
      "$value": "#72C152",
      "$type": "color",
      "$description": "— nature green used for life/growth metaphors"
    }
  },
  "typography": {
    "display": {
      "$value": "Frutiger (or Myriad Pro as fallback)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Trebuchet MS",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.01em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "8px",
      "$type": "dimension"
    }
  }
}
