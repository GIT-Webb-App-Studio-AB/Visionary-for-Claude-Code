{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "ecommerce-retail — industry / Expressive",
  "color": {
    "bg": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "trust signal — product photography needs clean background"
    },
    "accent": {
      "$value": "#FF4D00",
      "$type": "color",
      "$description": "urgency/sale signal"
    }
  },
  "typography": {
    "display": {
      "$value": "Cabinet Grotesk 700 (premium retail) or Bricolage Grotesque 700 (editorial retail)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "DM Sans 400",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "-0.02em",
      "$type": "dimension"
    },
    "leading": {
      "$value": 1.1,
      "$type": "number"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":280,\"damping\":24,\"mass\":0.9}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "8px",
      "$type": "dimension"
    }
  }
}
