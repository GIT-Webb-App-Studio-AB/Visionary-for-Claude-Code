{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "bloomberg-terminal — industry / Subtle",
  "color": {
    "bg": {
      "$value": "#000000",
      "$type": "color"
    },
    "primary": {
      "$value": "#FFB300",
      "$type": "color",
      "$description": "amber) or #00FF00 (green) — pick one, never both"
    },
    "accent": {
      "$value": "#333333",
      "$type": "color"
    }
  },
  "typography": {
    "display": {
      "$value": "JetBrains Mono 700",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "JetBrains Mono 400",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.02em",
      "$type": "dimension"
    },
    "leading": {
      "$value": 1.4,
      "$type": "number"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":600,\"damping\":40,\"mass\":0.5}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
