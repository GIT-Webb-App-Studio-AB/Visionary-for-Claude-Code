{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "smoked-glass-chrome — extended / Expressive",
  "color": {
    "bg": {
      "$value": "#0D0D0F",
      "$type": "color",
      "$description": "near-black"
    },
    "primary": {
      "$value": "#C0C0C0",
      "$type": "color",
      "$description": "chrome"
    }
  },
  "typography": {
    "display": {
      "$value": "Inter (or Geist)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Inter",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "-0.01em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":260,\"damping\":22}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius-min": {
      "$value": "12px",
      "$type": "dimension"
    },
    "radius-max": {
      "$value": "16px",
      "$type": "dimension"
    }
  }
}
