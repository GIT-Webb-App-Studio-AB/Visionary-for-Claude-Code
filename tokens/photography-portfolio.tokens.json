{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "photography-portfolio — hybrid / Expressive",
  "color": {
    "bg": {
      "$value": "#111111",
      "$type": "color",
      "$description": "near-black — photographs read best on dark"
    },
    "primary": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "white type on dark"
    },
    "accent": {
      "$value": "#888888",
      "$type": "color",
      "$description": "secondary text grey"
    }
  },
  "typography": {
    "display": {
      "$value": "Playfair Display",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Source Sans 3",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.01em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":200,\"damping\":20}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
