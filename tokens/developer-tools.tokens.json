{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "developer-tools — industry / Subtle",
  "color": {
    "bg": {
      "$value": "#0D1117",
      "$type": "color",
      "$description": "dark) or #FFFFFF (light"
    },
    "primary": {
      "$value": "#7C3AED",
      "$type": "color",
      "$description": "developer violet"
    },
    "accent": {
      "$value": "#06B6D4",
      "$type": "color",
      "$description": "cyan for syntax highlights"
    },
    "elevation-model": {
      "$value": "#30363D",
      "$type": "color",
      "$description": "subtle borders (1px solid  dark / #E2E8F0 light"
    }
  },
  "typography": {
