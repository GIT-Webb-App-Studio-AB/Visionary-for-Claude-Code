{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "future-medieval — graphic / Expressive",
  "color": {
    "bg": {
      "$value": "#0D0D1A",
      "$type": "color",
      "$description": "dark vellum"
    },
    "primary": {
      "$value": "#C9A84C",
      "$type": "color",
      "$description": "illuminated gold"
    },
    "accent": {
      "$value": "#6B1A2A",
      "$type": "color",
      "$description": "blood manuscript"
    }
  },
  "typography": {
    "display": {
      "$value": "MedievalSharp (or UnifrakturMaguntia)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Cinzel",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.04em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Expressive",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":160,\"damping\":20}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius-min": {
      "$value": "0px",
      "$type": "dimension"
    },
    "radius-max": {
      "$value": "2px",
      "$type": "dimension"
    }
  }
}
