      "$type": "color",
      "$description": "cream"
    },
    "primary": {
      "$value": "#1C1C1C",
      "$type": "color",
      "$description": "archive black"
    },
    "accent": {
      "$value": "#7A2030",
      "$type": "color",
      "$description": "burgundy — library binding reference"
    }
  },
  "typography": {
