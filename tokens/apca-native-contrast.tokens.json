    "large-text": {
      "$value": "#D1D1D1",
      "$type": "color",
      "$description": "`` (Lc ≈ -78"
    },
    "muted-text": {
      "$value": "#555555",
      "$type": "color",
      "$description": "`` (Lc ≈ 60 — UI label only, never body"
    },
    "primary": {
      "$value": "#4D9AFF",
      "$type": "color",
      "$description": "`` (Lc ≈ -72 for body-text-on-primary"
    },
    "accent": {
      "$value": "#FFB366",
      "$type": "color",
      "$description": "`` (Lc ≈ -75"
