{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "legal-editorial — extended / Subtle",
  "color": {
    "bg": {
      "$value": "#FFFFFF",
      "$type": "color",
      "$description": "legal documents are white"
    },
    "primary": {
      "$value": "#1A1A1A",
      "$type": "color",
      "$description": "black — legal ink"
    },
    "accent": {
      "$value": "#6B1A2A",
      "$type": "color",
      "$description": "law burgundy — case law references, section headers"
    }
  },
  "typography": {
    "display": {
      "$value": "Times New Roman (or Libre Baskerville)",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Libre Baskerville",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":200,\"damping\":30}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "0px",
      "$type": "dimension"
    }
  }
}
