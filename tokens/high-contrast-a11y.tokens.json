{
  "$schema": "https://design-tokens.github.io/spec/draft/schema.json",
  "$description": "high-contrast-a11y — modern / Subtle",
  "color": {
    "bg": {
      "$value": "#FFFFFF",
      "$type": "color"
    },
    "primary": {
      "$value": "#000000",
      "$type": "color"
    },
    "accent": {
      "$value": "#0000EE",
      "$type": "color",
      "$description": "pure link blue — accessible by convention"
    },
    "elevation-model": {
      "$value": "#000000",
      "$type": "color",
      "$description": "2px solid  borders replace all shadow-based elevation"
    }
  },
  "typography": {
    "display": {
      "$value": "Atkinson Hyperlegible",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Atkinson Hyperlegible",
      "$type": "fontFamily"
    },
    "tracking": {
      "$value": "0.01em",
      "$type": "dimension"
    }
  },
  "motion": {
    "tier": {
      "$value": "Subtle",
      "$type": "other"
    },
    "spring": {
      "$value": "{\"stiffness\":400,\"damping\":40}",
      "$type": "other",
      "$description": "Motion v12 two-parameter spring (bounce/visualDuration) or v11 legacy (stiffness/damping/mass)."
    }
  },
  "spacing": {
    "base": {
      "$value": "8px",
      "$type": "dimension",
      "$description": "Base grid unit (all spacing is a multiple of this)."
    },
    "radius": {
      "$value": "4px",
      "$type": "dimension"
    }
  }
}
